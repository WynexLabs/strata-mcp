{
  "name": "@wynexlabs/strata-mcp",
  "version": "0.1.0",
  "description": "MCP (Model Context Protocol) server exposing Strata's numerical finance compute endpoints (bond pricing, BSM + American options, portfolio VaR) as stdio tools for Claude Desktop / Cursor / other MCP clients.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "strata-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:run": "vitest run",
    "smoke": "npm run build && node scripts/smoke-stdio.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=18.17"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
